# =============================================================================
# IntraBase — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=intrabase
POSTGRES_USER=intrabase_admin
POSTGRES_PASSWORD=change_this_strong_password_here

# Full connection string (used by API service)
DATABASE_URL=postgresql://intrabase_admin:change_this_strong_password_here@pgbouncer:6432/intrabase

# Direct connection (used for migrations/init only)
DATABASE_DIRECT_URL=postgresql://intrabase_admin:change_this_strong_password_here@postgres:5432/intrabase

# -----------------------------------------------------------------------------
# Google OAuth 2.0
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Only users with this email domain can sign in (e.g. yourcompany.com)
ALLOWED_EMAIL_DOMAIN=yourcompany.com

# -----------------------------------------------------------------------------
# JWT Auth
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_32_chars

# Token expiry durations
JWT_ACCESS_TOKEN_EXPIRY=8h
JWT_REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# Application URLs
# Use http://localhost for local development
# -----------------------------------------------------------------------------
DASHBOARD_URL=http://localhost:3000
API_URL=http://localhost:3001

# URL that Google redirects back to after sign-in
# Must match exactly what is set in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_PORT=3001
NODE_ENV=development

# Rate limiting: requests per minute per user
RATE_LIMIT_PER_MINUTE=100

# -----------------------------------------------------------------------------
# Dashboard Service
# -----------------------------------------------------------------------------
DASHBOARD_PORT=3000

# Used by Next.js to communicate with API (server-side)
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# pgBouncer
# -----------------------------------------------------------------------------
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=20
